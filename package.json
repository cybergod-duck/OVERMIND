{
  "name": "overmind",
  "version": "4.0.0",
  "author": "Overmind",
  "description": "Personal AI For Your PC",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"electron electron-main.cjs\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ai.overmind",
    "productName": "Overmind",
    "files": [
      "dist",
      "electron-main.cjs",
      "preload.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "electron-store": "^6.0.1",
    "lucide-react": "^0.378.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.25.11",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wait-on": "^9.0.10"
  }
}
